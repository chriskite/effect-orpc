{
  "name": "@chriskite/effect-orpc",
  "version": "0.5.0",
  "description": "A type-safe integration between oRPC and Effect, enabling Effect-native procedures with service injection, OpenTelemetry tracing, and typesafe Effect errors.",
  "keywords": [
    "effect",
    "orpc"
  ],
  "homepage": "https://github.com/chriskite/effect-orpc#readme",
  "bugs": {
    "url": "https://github.com/chriskite/effect-orpc/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chriskite/effect-orpc.git"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "sideEffects": [
    "./dist/node.js"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "default": "./dist/node.js"
    }
  },
  "scripts": {
    "build": "tsup && bun run sync:readme",
    "build:watch": "bun run build --watch",
    "type:check": "tsc -b",
    "lint:check": "oxlint",
    "format:check": "oxfmt --check",
    "check": "bun run format:check && bun run lint:check && bun run type:check",
    "format": "oxfmt",
    "test": "vitest ./tests",
    "sync:readme": "bun ../../scripts/sync-package-readme.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "effect": "^3.18.4",
    "oxfmt": "^0.21.0",
    "oxlint": "^1.36.0",
    "tsup": "^8.5.1",
    "vitest": "^4.0.18",
    "zod": "^4.3.4"
  },
  "peerDependencies": {
    "@orpc/client": "^1.13.0",
    "@orpc/contract": "^1.13.0",
    "@orpc/server": "^1.13.0",
    "@orpc/shared": "^1.13.0",
    "effect": "^3.18.0",
    "typescript": "^6"
  },
  "engines": {
    "bun": ">=1.2",
    "node": ">=20"
  }
}
